        <a class="btnlink" id="dl-best" href="/api/runs/${id}/best" target="_blank">베스트 개선본 ↗</a>
        ${run.input.origFormat ? `<a class="btnlink" id="dl-office" href="/api/runs/${id}/best/office">${icon('download')} .${run.input.origFormat} 다운로드</a>` : ''}
